# Server
PORT=8080
APP_ENV=development
APP_ORIGIN=http://localhost:3000
ENABLE_DEMO_MODE=false
DEMO_RESET_ENABLED=false

# Database (Neon Postgres locally or hosted). Use a separate branch/database for shared demos.
DATABASE_URL=postgres://user:password@host:5432/quorum?sslmode=require

# Auth (Neon Auth handles identity and sessions; Go handles Quorum authorization)
NEON_AUTH_ISSUER=https://replace-with-neon-auth-issuer
NEON_AUTH_JWKS_URL=https://replace-with-neon-auth-jwks-url
NEON_AUTH_AUDIENCE=replace-with-neon-auth-audience-if-required

# Cloudflare R2
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=quorum-dev
R2_PUBLIC_URL=https://replace-with-r2-public-or-custom-domain

# Bootstrap admin accounts
ADMIN_EMAILS=alex@example.com

# Browser-visible API endpoint for the Go GraphQL server.
NEXT_PUBLIC_API_URL=http://localhost:8080/graphql

# Neon Auth / Stack Auth frontend config.
# Fill these from the Neon Auth dashboard when frontend auth is wired.
NEXT_PUBLIC_STACK_PROJECT_ID=replace-with-stack-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=replace-with-stack-publishable-client-key
STACK_SECRET_SERVER_KEY=replace-with-stack-secret-server-key

# Browser-visible API endpoint for the Go GraphQL server.
NEXT_PUBLIC_API_URL=http://localhost:8080/graphql

# Neon Auth server-side proxy config for Next.js.
# Use the Auth URL from Neon, not the Data API REST URL.
NEON_AUTH_BASE_URL=https://replace-with-neon-auth-url
# Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=replace-with-at-least-32-characters
